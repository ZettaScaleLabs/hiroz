crates/hiroz-msgs/python/build/lib/hiroz_msgs_py/types/*.py
crates/hiroz-msgs/python/build/
crates/hiroz-msgs/python/uv.lock

# Generated by pre-commit hooks (from Nix dev shell)
/.pre-commit-config.yaml

# Markdownlint local config (managed by Nix)
.markdownlint.json

# mdBook build output
/book/book/
/book/*.js
/book/*.css

*.db
*.log

.claude
.mcp.json

