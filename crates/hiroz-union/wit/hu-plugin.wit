// hu plugin interface v0.1
//
// Host-proxied model: the host (hu) owns the Zenoh session. Plugins never
// handle raw CDR bytes — the host decodes to JSON before delivery.
// The render interface is the only output path; TUI and web hosts interpret
// it differently so the same .wasm plugin works in both.

package hu:plugin@0.1.0;

// Shared types used by the plugin world.
interface types {
    record keybinding {
        // Key name understood by the TUI, e.g. "h", "Ctrl+e".
        key: string,
        // Description shown in the TUI help overlay.
        description: string,
        // Opaque command string passed back as key-action event.
        command: string,
    }

    record plugin-manifest {
        name:        string,
        version:     string,
        description: string,
        // Keybindings active when this plugin's pane has focus.
        bindings:    list<keybinding>,
        // Tick interval in milliseconds (0 = no ticks).
        tick-ms:     u32,
    }

    variant plugin-event {
        // User pressed a registered keybinding; value is the command string.
        key-action(string),
        // Host TUI navigated to a topic.
        topic-selected(string),
        // Periodic tick at the interval declared in the manifest.
        tick,
    }
}

// Read-only snapshot of the live ROS graph.
// The host serves this from the liveliness index without any Zenoh round-trip.
interface graph {
    use types.{plugin-manifest};

    record topic-info {
        name:        string,
        type-name:   string,
        publishers:  u32,
        subscribers: u32,
    }
    record node-info {
        namespace: string,
        name:      string,
    }
    record service-info {
        name:      string,
        type-name: string,
        servers:   u32,
    }

    list-topics:   func() -> list<topic-info>;
    list-nodes:    func() -> list<node-info>;
    list-services: func() -> list<service-info>;
}

// ROS communication — host decodes CDR to JSON before delivery.
// Plugins never see raw CDR bytes; no per-plugin message codegen needed.
interface ros {
    // Active subscription to a topic.
    // Drop to unsubscribe.
    resource subscription {
        // Returns next decoded JSON message or none if the queue is empty.
        try-recv: func() -> option<string>;
    }

    // Service client for request/response calls.
    resource service-client {
        // Send a JSON-encoded request and block until a response arrives
        // or the timeout expires.
        call: func(request-json: string, timeout-ms: u32) -> result<string, string>;
    }

    // Subscribe to a topic; returns a subscription handle or an error.
    subscribe: func(topic: string) -> result<subscription, string>;

    // Connect to a named service; type-name e.g.
    // "example_interfaces/srv/AddTwoInts".
    connect-service: func(name: string, type-name: string) -> result<service-client, string>;

    // Host-side rate measurement — avoids passing raw timestamps across the
    // boundary for hz tracking. Returns average Hz over the last window-ms.
    measure-hz: func(topic: string, window-ms: u32) -> result<f64, string>;

    // Host-side bandwidth measurement. Returns average KB/s over window-ms.
    measure-bw: func(topic: string, window-ms: u32) -> result<f64, string>;
}

// Output interface — host interprets for its rendering target.
// TUI host: println → ratatui line in the plugin pane.
// Web host: println → WebSocket JSON event to the frontend.
// The same .wasm binary works in both hosts unchanged.
interface render {
    // Print a line of text.
    println: func(text: string);
    // Set the plugin pane title shown in the TUI tab bar.
    set-title: func(title: string);
    // Emit a structured key/value pair for richer web rendering (charts, tables).
    emit-json: func(key: string, value: string);
}

// The plugin world: what the host imports and what the plugin exports.
world hu-plugin {
    use types.{plugin-manifest, plugin-event};

    import graph;
    import ros;
    import render;

    // Called once at load time to discover the plugin's identity and keybindings.
    export manifest: func() -> plugin-manifest;
    // Called on every event the plugin subscribed to.
    export on-event: func(event: plugin-event);
}
